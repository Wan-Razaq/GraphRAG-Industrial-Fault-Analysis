# Required for the Streamlit chatbot and OpenAI embeddings
OPENAI_API_KEY=

# Required for Neo4j GraphRAG retrieval
NEO4J_URI=
NEO4J_USER=
NEO4J_PASS=

# Optional: link shown in the Streamlit app for opening a graph browser
NEO4J_BROWSER_URL=https://browser.neo4j.io/

# Optional providers used by some BAML/notebook experiments
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
DEKA_API_KEY=
GROQ_API_KEY=
